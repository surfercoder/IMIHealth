{
  "expo": {
    "name": "IMI Health",
    "slug": "IMIHealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "imihealth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imihealth.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "IMI Health uses the microphone to record consultations so we can transcribe and generate medical reports.",
        "NSSpeechRecognitionUsageDescription": "IMI Health uses speech recognition to transcribe medical orders in real time.",
        "NSPhotoLibraryUsageDescription": "IMI Health needs photo library access to set your profile picture.",
        "NSCameraUsageDescription": "IMI Health can use the camera to capture your profile picture.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.imihealth.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#0f172a"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "IMI Health uses the microphone to record consultations so we can transcribe and generate medical reports."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "IMI Health uses the microphone to transcribe medical orders as you dictate them.",
          "speechRecognitionPermission": "IMI Health uses speech recognition to transcribe medical orders in real time."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1e1b4b"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "apiBaseUrl": ""
    }
  }
}
